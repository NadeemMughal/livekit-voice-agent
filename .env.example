# ====== REQUIRED API KEYS ======
# Get these from the provider consoles and fill them in below

# Deepgram (STT) — https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Gemini (LLM) — https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs (TTS) — https://elevenlabs.io/app/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ====== LIVEKIT SERVER ======
# These are from your LiveKit server deployment (self-hosted or cloud)

# API key for agent authentication
LIVEKIT_API_KEY=your_livekit_api_key_here

# API secret for token signing (KEEP SECURE!)
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# WebSocket URL to your LiveKit server (e.g., wss://livekit.example.com)
LIVEKIT_URL=wss://your_livekit_host_here

# ====== OPTIONAL: MODEL & VOICE SETTINGS ======

# Gemini model ID (see available models at https://ai.google.dev)
MODEL_GEMINI=gbf-2.0-flash-lite

# ElevenLabs voice ID for TTS (e.g., alloy, fable, luna)
ELEVEN_VOICE_ID=alloy
