# LiveKit Token Server Configuration

# LiveKit API credentials (for token signing)
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# LiveKit server URL (what to return in token envelope)
LIVEKIT_URL=wss://your_livekit_host_here

# Token server port (default: 3001)
PORT=3001
